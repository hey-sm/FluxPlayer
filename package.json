{
  "name": "fluxplayer",
  "productName": "FluxPlayer",
  "version": "2.0.0-alpha.1",
  "description": "FluxPlayer — 沉浸式桌面音乐播放器",
  "author": "FluxPlayer",
  "license": "GPL-3.0",
  "private": true,
  "main": "out/main/index.mjs",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-winstaller",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "oxlint",
    "format": "oxfmt --check",
    "format:write": "oxfmt",
    "test": "vitest run",
    "test:e2e": "pnpm build && playwright test",
    "smoke": "node scripts/smoke.mjs",
    "record:fixtures": "node scripts/record-fixtures.mjs",
    "build:win": "electron-vite build && electron-builder --win nsis",
    "build:win:dir": "electron-vite build && electron-builder --win dir"
  },
  "dependencies": {
    "electron-updater": "6.8.9"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.66.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.8.0",
    "vite": "^8.1.3",
    "vitest": "^3.0.0",
    "zustand": "^5.0.3",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "NeteaseCloudMusicApi": "4.32.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "react-glass-ui": "1.2.2",
    "tailwind-merge": "^3.6.0",
    "three": "0.185.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  }
}
