{
  "name": "fluxplayer",
  "productName": "FluxPlayer",
  "version": "2.0.0-alpha.1",
  "description": "FluxPlayer — 沉浸式桌面音乐播放器（工程化重构版）",
  "author": "FluxPlayer",
  "license": "GPL-3.0",
  "private": true,
  "main": "out/main/index.mjs",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-winstaller",
      "koffi",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "electron-vite dev",
    "dev:legacy": "node scripts/with-env.mjs FLUX_LEGACY=1 electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "pnpm build && playwright test",
    "smoke": "node scripts/smoke.mjs",
    "record:fixtures": "node scripts/record-fixtures.mjs",
    "sync-legacy": "node scripts/sync-legacy.mjs",
    "build:win": "electron-vite build && electron-builder --win nsis",
    "build:win:dir": "electron-vite build && electron-builder --win dir"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "NeteaseCloudMusicApi": "^4.32.0",
    "electron-updater": "6.8.9",
    "hono": "^4.7.0",
    "koffi": "3.1.1",
    "music-tempo": "^1.0.3",
    "three": "0.128.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@playwright/test": "1.61.1",
    "@tanstack/react-query": "^5.66.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "0.128.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-glass-ui": "1.2.2",
    "sharp": "^0.33.5",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^8.1.3",
    "vitest": "^3.0.0",
    "zustand": "^5.0.3"
  }
}
